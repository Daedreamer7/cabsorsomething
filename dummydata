-- Insert Teams
insert into public.teams (name, department_id, leader_id) 
select 'Production Team A', d.id, e.id
from public.departments d, public.employees e
where d.name = 'Cabinet Production' and e.email = 'michael@gentryscabinets.com';

insert into public.teams (name, department_id, leader_id)
select 'Installation Team A', d.id, e.id
from public.departments d, public.employees e
where d.name = 'Installation' and e.email = 'david@gentryscabinets.com';

-- Insert Team Members
insert into public.team_members (team_id, employee_id, role)
select t.id, e.id, 'Member'
from public.teams t, public.employees e
where t.name = 'Production Team A' and e.department = 'Cabinet Production';

insert into public.team_members (team_id, employee_id, role)
